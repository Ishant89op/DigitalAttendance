# Normalize text files to LF in the repository.
* text=auto eol=lf

# Keep Windows-native scripts with CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Treat binary assets as binary to avoid line-ending normalization.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.db binary
*.sqlite3 binary
*.onnx binary
